// --- 3. LÓGICA E EVENTOS ---

// Configurar âncoras de scroll ao carregar
window.addEventListener("load", function () {
    var divComeco = document.querySelector(".comeco");
    if (divComeco) divComeco.id = "inicio";
    var divCardapio = document.querySelector(".cardapio");
    if (divCardapio) divCardapio.id = "cardapio";
});

// Eventos dos botões de Login/Cadastro existentes na página
document.addEventListener("DOMContentLoaded", function() {
    var botoes = document.querySelectorAll(".btn-personalizado");
    if(botoes[0]) botoes[0].addEventListener("click", function() { abrirFormulario("login"); });
    if(botoes[1]) botoes[1].addEventListener("click", function() { abrirFormulario("cadastro"); });
});

// Funções do Modal
function abrirFormulario(modo) {
    modoAtual = modo;
    document.getElementById("inputUsuario").value = "";
    document.getElementById("inputSenha").value = "";
    document.getElementById("erroUsuario").textContent = "";
    document.getElementById("erroSenha").textContent = "";
    document.getElementById("erroGeral").textContent = "";
    document.getElementById("tituloModal").textContent = (modo === "login") ? "🔑 Login" : "📝 Cadastro";
    modal.style.display = "flex";
}

function fecharModal() { modal.style.display = "none"; }

function confirmarFormulario() {
    var usuario = document.getElementById("inputUsuario").value.trim();
    var senha = document.getElementById("inputSenha").value.trim();
    var erroU = document.getElementById("erroUsuario");
    var erroS = document.getElementById("erroSenha");
    var erroG = document.getElementById("erroGeral");

    erroU.textContent = erroS.textContent = erroG.textContent = "";
    if (usuario === "" || senha === "") {
        if (usuario === "") erroU.textContent = "⚠ Preencha o usuário!";
        if (senha === "") erroS.textContent = "⚠ Preencha a senha!";
        return;
    }

    if (modoAtual === "login") {
        if (usuario === usuarioCorreto && senha === senhaCorreta) {
            fecharModal();
            alert("✅ Login realizado! Bem-vindo, " + usuario + "!");
        } else {
            erroG.textContent = "❌ Usuário ou senha incorretos!";
        }
    } else {
        if (senha.length < 4) {
            erroS.textContent = "⚠ A senha deve ter pelo menos 4 caracteres!";
            return;
        }
        fecharModal();
        alert("✅ Cadastro realizado! Olá, " + usuario + "!");
    }
}

// Funções do Menu e Navegação
function toggleMenu() {
    var menu = document.getElementById("menuNav");
    menu.style.display = (menu.style.display === "none") ? "block" : "none";
}

document.addEventListener("click", function (e) {
    var menuDiv = document.getElementById("menuHamburguer");
    if (menuDiv && !menuDiv.contains(e.target)) {
        document.getElementById("menuNav").style.display = "none";
    }
});

function irPara(id) {
    var elemento = document.getElementById(id);
    if (elemento) elemento.scrollIntoView({ behavior: "smooth" });
    document.getElementById("menuNav").style.display = "none";
}

function ativarSecao(id) {
    var secao = document.getElementById(id);
    if (secao) {
        secao.style.display = "block";
        irPara(id);
    }
}

function desativarSecao(id) {
    var secao = document.getElementById(id);
    if (secao) secao.style.display = "none";
    document.getElementById("menuNav").style.display = "none";
}